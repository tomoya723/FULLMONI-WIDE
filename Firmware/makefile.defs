################################################################################
# EEZ Framework integration (eez-flow.cpp bundled by EEZ Studio)
# This file is included by e2 studio auto-generated makefile via:
#   -include ../makefile.defs
################################################################################

# EEZ Flow runtime - single-file bundle generated by EEZ Studio Build
EEZ_FLOW_SRC := ../src/ui/eez-flow.cpp
EEZ_FLOW_OBJ := src/ui/eez-flow.o

# Compile eez-flow.cpp with rx-elf-g++ (C++14)
$(EEZ_FLOW_OBJ): $(EEZ_FLOW_SRC)
	@echo 'Building EEZ Flow runtime: $<'
	rx-elf-g++ -Os -ffunction-sections -fdata-sections -fno-strict-aliasing -g3 \
		-mcpu=rx72t -misa=v3 -mlittle-endian-data \
		-std=gnu++14 -fno-exceptions -fno-rtti -fno-threadsafe-statics -fno-use-cxa-atexit \
		-I"$(abspath ../src)" -I"$(abspath ../src/ui)" \
		-I"$(abspath ../src/lvgl)" \
		-I"$(abspath ../src/smc_gen/r_bsp)" \
		-I"$(abspath ../src/smc_gen)" \
		-MMD -MP -c "$<" -o "$@"

USER_OBJS += $(EEZ_FLOW_OBJ)

# Image file generated by EEZ Studio Flow (not yet in e2 studio subdir.mk)
EEZ_IMG_SRC := ../src/ui/images/ui_image_ui_img_fmw_op0_png.c
EEZ_IMG_OBJ := src/ui/images/ui_image_ui_img_fmw_op0_png.o
$(EEZ_IMG_OBJ): $(EEZ_IMG_SRC)
	@echo 'Building EEZ image: $<'
	rx-elf-gcc -Og -ffunction-sections -fdata-sections -fno-strict-aliasing -g3 \
		-mcpu=rx72t -misa=v3 -mlittle-endian-data -std=gnu99 \
		-I"$(abspath ../src)" \
		-MMD -MP -c "$<" -o "$@"
USER_OBJS += $(EEZ_IMG_OBJ)

# C++ standard library (needed for EEZ Framework C++ code)
LIBS += -lstdc++
